PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/livetrack_web
JWT_SECRET=replace_with_secure_jwt_secret

# Required for browser clients. Comma-separated list, no spaces after commas.
# Example: https://your-app.vercel.app,https://your-app.onrender.com,http://localhost:5173
CORS_ORIGIN=http://localhost:5173

NODE_ENV=production

# Optional — password reset emails (see src/services/emailService.js)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

MOBILE_INGEST_KEY=
TASK_COLLECTION=

DEFAULT_ADMIN_NAME=LiveTrack Admin
DEFAULT_ADMIN_EMAIL=h@gmail.com
DEFAULT_ADMIN_PASSWORD=web123
