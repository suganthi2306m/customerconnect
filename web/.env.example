# Copy to `.env` for local. On Vercel, set Production (and Preview if needed) env vars there.
#
# Dashboard → web_backend only (not customerconnect-mobile-api).
# Vercel Production example:
#   VITE_API_BASE_URL=https://customerconnect-web-api.onrender.com/api
#   VITE_SOCKET_URL=https://customerconnect-web-api.onrender.com
#
VITE_API_BASE_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000
VITE_GOOGLE_MAPS_API_KEY=
